            "url": "{{baseUrl}}/restaurant/menu/find-by-name?name=dosa"
          }
        },
        {
          "name": "Upsert Menu",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imageUrl\": \"https://example.com/item.jpg\",\n  \"name\": \"Cheese Dosa\",\n  \"description\": \"Crispy dosa with cheese\",\n  \"actualPrice\": 180,\n  \"discountedPrice\": 150,\n  \"availableFrom\": 1710000000000,\n  \"quantity\": 20\n}"
            },
            "url": "{{baseUrl}}/restaurant/menu/upsert"
          }
        },
        {
          "name": "Restaurant Orders",
          "request": {
            "method": "GET",
