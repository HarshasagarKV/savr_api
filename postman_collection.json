            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeName\": \"Namma Bowl Kitchen\",\n  \"ownerName\": \"Arun Kumar\",\n  \"phone\": \"+919900000101\",\n  \"email\": \"namma@savr.com\",\n  \"address\": \"12 MG Road, Bengaluru\",\n  \"cuisine\": \"South Indian\",\n  \"openTimeEpoch\": 1710000000000,\n  \"closeTimeEpoch\": 1710030000000,\n  \"latitude\": 12.9756,\n  \"longitude\": 77.605\n}"
            },
