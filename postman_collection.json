            "url": "{{baseUrl}}/restaurant/orders?status=placed"
          }
        },
        {
          "name": "Complete Restaurant Order",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/restaurant/orders/{{orderId}}/complete"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/overview"
          }
        },
